# ──────────────────────────────────────────────────────────────────────────────
# AI Resume Screening System — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys. Never commit .env to Git.
#
# FREE API KEYS — where to get them:
# ─────────────────────────────────
# GROQ_API_KEY  → https://console.groq.com/  (free, no credit card needed)
#                 Sign up → API Keys → Create API Key
#                 Model used: llama-3.3-70b-versatile (completely free)
#
# LANGCHAIN_API_KEY → https://smith.langchain.com/  (free developer plan)
#                     Sign up → Settings → API Keys → Create API Key
# ──────────────────────────────────────────────────────────────────────────────

# ── Groq (LLM backend — free tier) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LangSmith (tracing & monitoring — free developer plan) ───────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ai-resume-screener
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
